{
	"show_whitespaces": "all",
	"sticky_scroll": {
		"enabled": true
	},
	"edit_predictions": {
		"provider": "none"
	},
	"buffer_font_features": {
		"calt": false
	},
	"buffer_font_size": 13,
	"buffer_line_height": {
		"custom": 2
	},
	"base_keymap": "JetBrains",
	"disable_ai": false,
	"excerpt_context_lines": 3,
	"languages": {
		"CSS": { "formatter": { "language_server": { "name": "biome" } } },
		"HTML": { "formatter": { "language_server": { "name": "biome" } } },
		"JSON": { "formatter": { "language_server": { "name": "biome" } } },
		"JSONC": { "formatter": { "language_server": { "name": "biome" } } },
		"JavaScript": {
			"formatter": { "language_server": { "name": "biome" } },
			"code_actions_on_format": {
				"source.fixAll.biome": true,
				"source.organizeImports.biome": true
			}
		},
		"TSX": {
			"formatter": { "language_server": { "name": "biome" } },
			"code_actions_on_format": {
				"source.fixAll.biome": true,
				"source.organizeImports.biome": true
			}
		},
		"TypeScript": {
			"formatter": { "language_server": { "name": "biome" } },
			"code_actions_on_format": {
				"source.fixAll.biome": true,
				"source.organizeImports.biome": true
			}
		},
		"Ruby": {
			"language_servers": ["ruby-lsp", "rubocop", "!solargraph"]
		}
	},
	"lsp": {
		"biome": {
			"settings": {
				"require_config_file": true
			}
		},
		"rubocop": {
			"binary": {
				"path": "/Users/david/.local/share/mise/installs/ruby/3.4.7/bin/rubocop",
				"arguments": ["--no-server", "--lsp"]
			}
		}
	},
	"minimap": {
		"show": "always",
		"thumb": "always",
		"current_line_highlight": null
	},
	"preview_tabs": {
		"enabled": false
	},
	"show_wrap_guides": true,
	"tab_bar": {
		"show": true
	},
	"telemetry": {
		"diagnostics": false,
		"metrics": false
	},
	// "terminal": {
	//   "dock": "right"
	// },
	"theme": "Zedokai (Filter Octagon)",
	"ui_font_size": 16,
	"vim": {
		"use_smartcase_find": true,
		"toggle_relative_line_numbers": true
	},
	"vim_mode": true,
	"wrap_guides": [80, 100]
}
