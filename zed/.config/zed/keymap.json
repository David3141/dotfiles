[
	// Global
	{
		"context": "Workspace",
		"bindings": {
    		// Debugger panel
			"ctrl-\\": "workspace::ToggleBottomDock",
			"ctrl-s": "workspace::Save"
		}
	},
	// Window navigation
	{
		"context": "Dock || Terminal || Editor",
		"bindings": {
			// Window's motions
			"ctrl-h": "workspace::ActivatePaneLeft",
			"ctrl-l": "workspace::ActivatePaneRight",
			"ctrl-k": "workspace::ActivatePaneUp",
			"ctrl-j": "workspace::ActivatePaneDown"
		}
	},
	{
		"context": "GitPanel",
		"bindings": {
			"q": "git_panel::Close"
		}
	},
	{
		"context": "AgentPanel",
		"bindings": {
			"ctrl-/": "workspace::ToggleRightDock"
		}
	},
	{
		"context": "Terminal",
		"bindings": {
			"ctrl-/": "workspace::ToggleRightDock",
			// Fix lazygit commands
			"ctrl-j": ["terminal::SendKeystroke", "ctrl-j"],
			"ctrl-k": ["terminal::SendKeystroke", "ctrl-k"]
		}
	},
	// File panel (netrw)
	{
		"context": "ProjectPanel && not_editing",
		"bindings": {
			"a": "project_panel::NewFile",
			"A": "project_panel::NewDirectory",
			"r": "project_panel::Rename",
			"d": "project_panel::Delete",
			"x": "project_panel::Cut",
			"c": "project_panel::Copy",
			"p": "project_panel::Paste",

			// Close project panel as project file panel on the right
			"q": "workspace::ToggleLeftDock",
			"space e": "workspace::ToggleLeftDock",
			":": "command_palette::Toggle",
			"%": "project_panel::NewFile",
			"/": "project_panel::NewSearchInDirectory",
			"space s g": "project_panel::NewSearchInDirectory",
			"enter": "project_panel::OpenPermanent",
			"escape": "project_panel::ToggleFocus",
			"h": "project_panel::CollapseSelectedEntry",
			"j": "menu::SelectNext",
			"k": "menu::SelectPrevious",
			"l": "project_panel::ExpandSelectedEntry",
			"o": "project_panel::OpenPermanent",
			"shift-d": "project_panel::Delete",
			"shift-r": "project_panel::Rename",
			"t": "project_panel::OpenPermanent",
			"v": "project_panel::OpenPermanent",
			"shift-g": "menu::SelectLast",
			"g g": "menu::SelectFirst",
			"-": "project_panel::SelectParent",
			"ctrl-6": "pane::AlternateFile"
		}
	},
	// Empty pane, set of keybindings that are available when there is no active editor
	{
		"context": "EmptyPane || SharedScreen",
		"bindings": {
			// Open file finder
			"space space": "file_finder::Toggle",
			// New file
			"space f n": "workspace::NewFile",
			// Open recent project
			"space f p": "projects::OpenRecent",

			// Quit zed
			"space q q": "zed::Quit"
		}
	},
	{
		"context": "Editor && VimControl && !VimWaiting && !menu",
		"bindings": {
			// New file
			"space f n": "workspace::NewFile",
			// Refactoring
			"space c r ": "editor::Rename",
			// Chat with AI
			"space a a": "agent::ToggleFocus",
			"ctrl-/": "terminal_panel::ToggleFocus",
			"cmd-k": "workspace::ToggleRightDock",
			"space a e": "assistant::InlineAssist",
			"cmd-l": "assistant::InlineAssist",
			"space a t": "workspace::ToggleRightDock",
			// Git
			"space g g": [
				"task::Spawn",
				{
					"task_name": "Lazygit",
					"reveal_target": "center"
				}
			],
			"space g b": "git::Blame",
			"space g d": "editor::ToggleHunkDiff",
			"space g D": "git::Diff",
			"space g r": "git::Restore",
			"space g R": "git::RestoreFile",

			"space m p": "markdown::OpenPreview",
			"space m P": "markdown::OpenPreviewToTheSide",

			// Open recent project
			"space f p": "projects::OpenRecent",

			// Search word under cursor in all panes
			"space s W": "pane::DeploySearch",
			"space s g": "pane::DeploySearch",

			// Grug-far, kinda
			"space s r": ["pane::DeploySearch", { "replace_enabled": true }],

			// Tab things. Almost as good as harpoon.
			"space 1": ["pane::ActivateItem", 0],
			"space 2": ["pane::ActivateItem", 1],
			"space 3": ["pane::ActivateItem", 2],
			"space 4": ["pane::ActivateItem", 3],
			"space 5": ["pane::ActivateItem", 4],
			"space 6": ["pane::ActivateItem", 5],
			"space 7": ["pane::ActivateItem", 6],
			"space 8": ["pane::ActivateItem", 7],
			"space 9": ["pane::ActivateItem", 8],
			"space 0": "pane::ActivateLastItem",

			// Buffers
			"L": "pane::ActivateNextItem",
			"H": "pane::ActivatePreviousItem",

			"space b l": "pane::CloseItemsToTheRight",
			"space b h": "pane::CloseItemsToTheLeft",
			"space b a": "pane::ReopenClosedItem",
			"space b o": "pane::CloseOtherItems",
			"space b d": "pane::CloseActiveItem",
			"space b b": "pane::AlternateFile",

			// Current buffers
			"space ,": "tab_switcher::Toggle",

			// LSP & Code actions
			"space c a": "editor::ToggleCodeActions",
			"space x x": "diagnostics::Deploy",
			"space s s": "outline::Toggle",
			"space s S": "project_symbols::Toggle",
			"space c f": "editor::Format",
			"space c o": "editor::OrganizeImports",

			// File explorer
			"space e": "workspace::ToggleLeftDock",

			// Telescope
			"space f f": "file_finder::Toggle",
			"space f r": "file_finder::Toggle",
			"space space": "file_finder::Toggle",

			// Quit zed
			"space q q": "zed::Quit",

			// Window management
			"space -": "pane::SplitDown",
			"space |": "pane::SplitRight",
			"space w d": "pane::CloseAllItems",

			// Move lines
			"alt-j": "editor::MoveLineDown",
			"alt-k": "editor::MoveLineUp",

			// Jump to hunk
			"] h": "editor::GoToHunk",
			"[ h": "editor::GoToPreviousHunk",

			// Jump to diagnostic
			"] d": "editor::GoToDiagnostic",
			"[ d": "editor::GoToPreviousDiagnostic",

			// Jump to excerpts
			"] q": "editor::MoveToStartOfNextExcerpt",
			"[ q": "editor::MoveToStartOfExcerpt",
			"cmd-shift-enter": "editor::OpenExcerpts",

			// Surround
			"g s": null,
			"g s a": "vim::PushAddSurrounds",
			"g s d": "vim::PushDeleteSurrounds",
			"g s r": "vim::PushChangeSurrounds"
		}
	},
	{
	  // Yank from cursor until end of line
		"context": "Editor && vim_mode == normal && !menu",
		"bindings": {
			"shift-y": ["workspace::SendKeystrokes", "y $"]
		}
	},
	{
		// Keep selection when indenting in visual mode
		"context": "Editor && (vim_mode == visual || vim_mode == visual_line)",
		"bindings": {
			">": ["workspace::SendKeystrokes", "> g v"],
			"<": ["workspace::SendKeystrokes", "< g v"]
		}
	},
	// Center cursor when scrolling and find all references
	{
		"context": "VimControl && !menu",
		"bindings": {
			"ctrl-d": ["workspace::SendKeystrokes", "ctrl-d z z"],
			"ctrl-u": ["workspace::SendKeystrokes", "ctrl-u z z"],
			"g r": "editor::FindAllReferences"
		}
	},
	{
		"context": "vim_mode == normal || vim_mode == visual",
		"bindings": {
		  // Sneak (hopefully we'll have flash soon)
			"s": "vim::PushSneak",
			"S": "vim::PushSneakBackward"
		}
	},
	// Mini.ai
	{
		"context": "vim_operator == a || vim_operator == i || vim_operator == cs",
		"bindings": {
			"b": "vim::MiniBrackets",
			"q": "vim::MiniQuotes"
		}
	},
	{
		"context": "ContextEditor > Editor",
		"bindings": {
			"ctrl-s": "workspace::Save"
		}
	},
	{
		"context": "vim_mode == insert",
		"bindings": {
		  // Saving enters normal mode
			"ctrl-s": ["workspace::SendKeystrokes", "cmd-s escape"]
		}
	},

	// Neotest, kinda
	{
		"context": "Editor && vim_mode == normal",
		"bindings": {
			"space t r": [
				"editor::SpawnNearestTask",
				{
					"reveal": "no_focus"
				}
			],
			"space t l": "task::Rerun"
		}
	},

	// Neotest TS / JS
	{
		"context": "Editor && vim_mode == normal && (extension == ts || extension == tsx || extension == js || extension == jsx)",
		"bindings": {
			"space t t": [
				"task::Spawn",
				{
  				// Ensure task exists in project
  				"task_name": "TS tests: current file"
				}
			]
		}
	},

	// Neotest Ruby
	{
		"context": "Editor && vim_mode == normal && extension == rb",
		"bindings": {
			"space t t": [
				"task::Spawn",
				{
  				// Ensure task exists in project
					"task_name": "Ruby tests: current file"
				}
			]
		}
	},
]
